from app.services.flood_service import predict_flood_risk
from app.services.landslide_service import predict_landslide
from app.services.earthquake_service import predict_earthquake
from app.services.map_service import get_nearest_safe_places


# -----------------------------
# MAIN ALERT ENGINE
# -----------------------------
def generate_alert(data: dict):

    # STEP 1: Get predictions
    flood = predict_flood_risk(data)
    landslide = predict_landslide(data)
    earthquake = predict_earthquake(data)

    alerts = []

    # STEP 2: Collect alerts
    if flood.get("alert"):
        alerts.append(flood)

    if landslide.get("alert"):
        alerts.append(landslide)

    if earthquake.get("alert"):
        alerts.append(earthquake)

    # STEP 3: SAFE CASE
    if len(alerts) == 0:
        return {
            "status": "SAFE",
            "notify": False,
            "alerts": [],
            "safe_places": None,
            "message": "✅ No disaster risk detected. You are safe."
        }

    # STEP 4: DANGER CASE → get safe places
    lat = data.get("lat")
    lon = data.get("lon")

    safe_places = None

    if lat is not None and lon is not None:
        safe_places = get_nearest_safe_places(lat, lon)

    # STEP 5: FINAL RESPONSE
    return {
        "status": "DANGER",
        "notify": True,
        "alerts": alerts,
        "safe_places": safe_places,
        "message": "🚨 Disaster risk detected! Move to safe location immediately."
    }